# DeepSeek models
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
PRIMARY_REVIEW_MODEL=deepseek-v4-flash
FALLBACK_REVIEW_MODEL=
PRIMARY_CHAT_MODEL=deepseek-v4-flash
FALLBACK_CHAT_MODEL=
CHAT_STREAM_MODEL=deepseek-v4-flash
REVIEW_TEMPERATURE=1.0
CHAT_TEMPERATURE=1.0
REPORT_TEMPERATURE=1.0
REVIEW_INITIAL_DEADLINE_SECONDS=38
REVIEW_ENTITY_TIMEOUT_SECONDS=8
REVIEW_ROUTING_TIMEOUT_SECONDS=4
REVIEW_MODEL_TIMEOUT_SECONDS=20
REVIEW_REPORT_TIMEOUT_SECONDS=35
REVIEW_HEARTBEAT_INTERVAL_SECONDS=8
PRIMARY_OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
FALLBACK_OCR_MODEL=
OCR_FALLBACK_API_KEY=your_siliconflow_api_key_here
OCR_FALLBACK_BASE_URL=https://api.siliconflow.cn/v1
OCR_MAX_UPLOAD_FILE_BYTES=20971520
OCR_MAX_BATCH_IMAGES=12
OCR_MAX_PDF_PAGES=20
OCR_MAX_IMAGE_PIXELS=20000000
REVIEW_QUEUE_MAX_RETRIES=2
OCR_QUEUE_MAX_RETRIES=2
QUEUE_RETRY_BACKOFF_SECONDS=1.5
INTERACTIVE_CHAT_TIMEOUT_SECONDS=25
INTERACTIVE_CHAT_MAX_TOKENS=640

# Redis cache / rate limit
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=7200
REDIS_SEARCH_TTL_SECONDS=1800
REDIS_LLM_TTL_SECONDS=3600
REDIS_AUTH_CODE_TTL_SECONDS=300

# PostgreSQL + pgvector
DATABASE_URL=postgresql://contract_user:contract_pass@localhost:5432/contract_review
AUTO_SEED_LEGAL_KNOWLEDGE=1

# Embeddings
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# JWT / CORS
JWT_SECRET=your_jwt_secret_here
JWT_SECRET_FILE=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOW_DEV_CODE_RESPONSE=false
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# SMTP (optional, for auxiliary email registration / login)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# Commercialization
FREE_REVIEW_COUNT=2
REVIEW_PRICE_FEN=100
REVIEW_QUESTION_QUOTA=15
EXTRA_QUESTION_PRICE_FEN=8
RECHARGE_MIN_AMOUNT_FEN=100
RECHARGE_QUICK_AMOUNTS=100,990,1990

# Aliyun SMS Verify（短信认证服务，只需这三项）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_ENDPOINT=https://dypnsapi.aliyuncs.com

# WeChat Pay Native
WECHAT_PAY_APPID=
WECHAT_PAY_MCHID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_KEY_PEM=
WECHAT_PAY_PLATFORM_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_PLATFORM_CERT_PEM=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com
